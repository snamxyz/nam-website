{
  "name": "nam-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev --workspace @nam/web",
    "dev:web": "npm run dev --workspace @nam/web",
    "dev:admin": "npm run dev --workspace @nam/admin",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build --workspace @nam/web",
    "build:admin": "npm run build --workspace @nam/admin",
    "start:web": "npm run start --workspace @nam/web",
    "start:admin": "npm run start --workspace @nam/admin",
    "lint": "eslint apps packages",
    "postinstall": "npm run db:generate",
    "db:generate": "npm run generate --workspace @nam/db",
    "db:migrate": "npm run migrate --workspace @nam/db",
    "db:push": "npm run push --workspace @nam/db",
    "db:seed": "npm run seed --workspace @nam/db",
    "test": "tsx --test packages/core/src/**/*.test.ts"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "gsap": "^3.14.2",
    "iron-session": "^8.0.4",
    "lenis": "^1.3.21",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ua-parser-js": "^2.0.10",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ua-parser-js": "^0.7.39",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
